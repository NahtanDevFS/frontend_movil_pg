{
  "expo": {
    "name": "MelonCount",
    "slug": "meloncount-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_meloncount.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2d6a4f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.amadeoexport.meloncount"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2d6a4f"
      },
      "package": "com.amadeoexport.meloncount",
      "permissions": ["READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-asset"],
    "scheme": "meloncount",
    "extra": {
      "apiUrl": "https://api.meloncount.win",
      "router": {},
      "eas": {
        "projectId": "92b1d13b-241f-43a5-8a26-fa6385c55c23"
      }
    }
  }
}
