{
  "expo": {
    "name": "MelonCount",
    "slug": "meloncount-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2d6a4f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.amadeoexport.meloncount"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2d6a4f"
      },
      "package": "com.amadeoexport.meloncount",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "meloncount",
    "extra": {
      "apiUrl": "https://reluctant-smartly-muppet.ngrok-free.dev"
    }
  },
  "dependencies": {
    "axios": "^1.16.0",
    "expo": "~54.0.0",
    "expo-asset": "~11.0.0",
    "expo-document-picker": "~13.0.0",
    "expo-file-system": "~18.0.0",
    "expo-print": "~14.0.0",
    "expo-router": "~5.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-sharing": "~13.0.0",
    "expo-status-bar": "~2.2.0",
    "react-native": "^0.76.9",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "~4.4.0"
  }
}
